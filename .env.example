# -----------------------------------------------------------------------------
# ThesisVault Environment Template
# Copy this to .env for local use, or add to your Cloud Platform secrets.
# -----------------------------------------------------------------------------

# --- FLASK CONFIG ---
# Values: production, development
FLASK_ENV=production
# Used for Flask-Security and JWT encryption
SECRET_KEY=generate-a-long-random-string-here
# Salt for password hashing
PASSWORD_SALT=another-long-random-string-here

# --- DATABASE ---
# Format for MySQL: mysql+pymysql://user:pass@host/dbname
DATABASE_URL=mysql+pymysql://your_user:your_password@your_host/your_db

# --- FRONTEND ---
# The URL where your Vue.js frontend is hosted
FRONTEND_URL=https://your-app.digitalocean.app
# Comma-separated list for CORS
CORS_ORIGINS=https://your-app.digitalocean.app

# --- CELERY / REDIS ---
# Required for background workers and task analysis
CELERY_BROKER_URL=redis://your-redis-host:6379/1
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/1

# --- AI SERVICES ---
# Your Google Gemini API Key
GEMINI_API_KEY=your-gemini-key-goes-here
GEMINI_MODEL=gemini-2.0-flash

# --- EMAIL ---
# SMTP settings for onboarding and submission emails
MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-username
MAIL_PASSWORD=your-password
MAIL_DEFAULT_SENDER=noreply@thesisvault.com
