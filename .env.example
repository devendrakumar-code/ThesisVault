# =============================================================================
# ThesisVault — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# =============================================================================

# --- Database ---
DATABASE_URL=mysql+pymysql://root:YOUR_DB_PASSWORD@localhost/thesis_vault_db

# --- Core Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_STRING
PASSWORD_SALT=CHANGE_ME_TO_ANOTHER_RANDOM_STRING

# --- Flask ---
FLASK_DEBUG=true

# --- Frontend / CORS ---
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TIMEZONE=Asia/Kolkata

# --- External Services ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Mail (Mailtrap for dev, real SMTP for production) ---
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=YOUR_MAILTRAP_USERNAME
MAIL_PASSWORD=YOUR_MAILTRAP_PASSWORD
MAIL_DEFAULT_SENDER=noreply@thesisvault.com

# --- Rate Limiting ---
RATELIMIT_STORAGE_URI=memory://

# --- Enrollment Limits ---
MAX_ENROLLMENTS_PER_PROJECT=500

# --- Token Settings ---
TOKEN_MAX_AGE=3600
